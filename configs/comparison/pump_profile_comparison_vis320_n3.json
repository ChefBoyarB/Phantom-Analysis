{
  "description": "Pump-profile comparison config for VIS320, aggregating multiple pump-off and pump-on runs with the same engine-style workflow as the other comparison tools.",
  "notes": [
    "Each condition can include any number of samples through analysis_config, run_path, or run_rel entries.",
    "This config compares three diffusion-only VIS320 runs against three VIS320 pump runs.",
    "It is intended to mirror the grouped GAD pump comparison workflow for like-for-like interpretation."
  ],
  "out_folder": "../../tmp_outputs/pump_profile_comparison_vis320_n3",
  "figure_title": "Pump Profile Comparison: VIS320 Pump Off vs Pump On",
  "tracer_name": "VIS320",
  "tracer_label": "VIS320",
  "time_unit_label": "min",
  "concentration_label": "Concentration (mg/mL)",
  "use_normalized_depth": true,
  "common_depth_points": 200,
  "normalize_each_profile_to_own_peak": true,
  "min_time_min": 0.0,
  "shared_time_axis_min": 0.0,
  "shared_time_axis_max": null,
  "target_times_min": [
    0.5,
    10.0,
    20.0
  ],
  "normalized_map_vmin": 0.0,
  "normalized_map_vmax": 1.0,
  "difference_map_abs_limit": 0.3,
  "deep_region_start": 0.67,
  "stats_alpha": 0.05,
  "report_windows": [
    {
      "name": "post_5min",
      "min_time_min": 5.0,
      "max_time_min": null
    }
  ],
  "conditions": [
    {
      "name": "pump_off",
      "label": "Pump off",
      "color": "#1f77b4",
      "marker": "o",
      "samples": [
        {
          "sample_id": "VIS_OFF_01",
          "analysis_config": "../analysis/diffusion/VIS320_Run_1.json"
        },
        {
          "sample_id": "VIS_OFF_02",
          "analysis_config": "../analysis/diffusion/VIS320_Run_2.json"
        },
        {
          "sample_id": "VIS_OFF_03",
          "analysis_config": "../analysis/diffusion/VIS320_Run_3.json"
        }
      ]
    },
    {
      "name": "pump_on",
      "label": "Pump on",
      "color": "#d95f02",
      "marker": "s",
      "samples": [
        {
          "sample_id": "VIS_ON_01",
          "analysis_config": "../analysis/ADE/VIS320_Pump_Run_1.json"
        },
        {
          "sample_id": "VIS_ON_02",
          "analysis_config": "../analysis/ADE/VIS320_Pump_Run_2.json"
        },
        {
          "sample_id": "VIS_ON_03",
          "analysis_config": "../analysis/ADE/VIS320_Pump_Run_3.json"
        }
      ]
    }
  ]
}
